<div class="search-container">
  <div class="search-header">
    <h1>Search Results</h1>
    <p class="search-query">
      <% if @query.present? %>
        Showing results for "<strong><%= @query %></strong>"
      <% else %>
        Enter a search term above
      <% end %>
    </p>
  </div>

  <div class="search-form-wrapper">
    <%= form_with url: search_products_path, method: :get, local: true, class: "search-form" do |form| %>
      <div class="search-input-group">
        <%= form.text_field :q, placeholder: "Search products by name or category...", value: @query, class: "search-input" %>
        <%= form.submit "Search", class: "search-btn" %>
      </div>
    <% end %>
  </div>

  <% if @query.present? %>
    <% if @products.any? %>
      <div class="search-results-header">
        <p class="results-count"><%= pluralize(@products.count, "product") %> found</p>
      </div>

      <div class="products-grid">
        <% @products.each do |product| %>
          <div class="product-card">
            <div class="product-image">
              <% if product.images.attached? && product.images.any? %>
                <%= link_to product_path(product) do %>
                  <%= image_tag product.images.first, alt: product.name, class: "card-image" %>
                <% end %>
              <% else %>
                <%= link_to product_path(product) do %>
                  <%= image_tag "https://via.placeholder.com/250x250?text=No+Image", alt: product.name, class: "card-image" %>
                <% end %>
              <% end %>
            </div>
            <div class="product-card-content">
              <h3 class="product-name">
                <%= link_to product.name, product_path(product) %>
              </h3>
              
              <% if product.category %>
                <p class="product-category">
                  <%= link_to product.category.name, category_path(product.category.slug), class: "category-link" %>
                </p>
              <% end %>

              <p class="product-description">
                <%= truncate(product.description, length: 100) %>
              </p>

              <div class="product-footer">
                <% if product.price.present? %>
                  <span class="product-price"><%= number_to_currency(product.price) %></span>
                <% end %>
                
                <div class="product-rating">
                  <% if product.review_count > 0 %>
                    <span class="rating-stars">
                      <% (1..5).each do |i| %>
                        <span class="star <%= i <= product.average_rating ? 'filled' : 'empty' %>">★</span>
                      <% end %>
                    </span>
                    <span class="rating-text">(<%= product.review_count %>)</span>
                  <% else %>
                    <span class="no-reviews">No reviews yet</span>
                  <% end %>
                </div>
              </div>

              <div class="product-actions">
                <%= link_to "View Product", product_path(product), class: "btn-view" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="no-results">
        <div class="no-results-icon">🔍</div>
        <h2>No products found</h2>
        <p>We couldn't find any products matching "<strong><%= @query %></strong>"</p>
        <p>Try searching with different keywords or browse our <%= link_to "all products", products_path %></p>
      </div>
    <% end %>
  <% end %>
</div>

<style>
  .search-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .search-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .search-header h1 {
    font-size: 2.5rem;
    color: #333;
    margin: 0 0 10px 0;
  }

  .search-query {
    font-size: 1.1rem;
    color: #666;
    margin: 0;
  }

  .search-form-wrapper {
    margin-bottom: 40px;
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .search-form {
    width: 100%;
  }

  .search-input-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .search-input {
    flex: 1;
    min-width: 250px;
    padding: 12px 16px;
    border: 2px solid #ddd;
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    transition: all 0.2s ease;
  }

  .search-input:focus {
    outline: none;
    border-color: #2c3e50;
    box-shadow: 0 0 0 3px rgba(44, 62, 80, 0.1);
  }

  .search-btn {
    padding: 12px 30px;
    background: #2c3e50;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .search-btn:hover {
    background: #34495e;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(44, 62, 80, 0.2);
  }

  .search-results-header {
    margin-bottom: 30px;
  }

  .results-count {
    font-size: 1.1rem;
    color: #666;
    margin: 0;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
    margin-bottom: 40px;
  }

  .product-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    transform: translateY(-4px);
  }

  .product-image {
    width: 100%;
    height: 250px;
    background: #f7f7f7;
    overflow: hidden;
  }

  .product-image a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-card-content {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-name {
    margin: 0 0 8px 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: #333;
    line-height: 1.4;
  }

  .product-name a {
    color: #333;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .product-name a:hover {
    color: #2c3e50;
  }

  .product-category {
    margin: 0 0 8px 0;
    font-size: 0.85rem;
    color: #888;
  }

  .category-link {
    color: #2c3e50;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .category-link:hover {
    color: #34495e;
    text-decoration: underline;
  }

  .product-description {
    margin: 0 0 12px 0;
    font-size: 0.9rem;
    color: #666;
    line-height: 1.5;
    flex: 1;
  }

  .product-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f0f0f0;
  }

  .product-price {
    font-size: 1.3rem;
    font-weight: 700;
    color: #2c3e50;
  }

  .product-rating {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
  }

  .rating-stars {
    display: flex;
    gap: 2px;
  }

  .star {
    font-size: 0.9rem;
  }

  .star.filled {
    color: #ffc107;
  }

  .star.empty {
    color: #ddd;
  }

  .rating-text {
    color: #888;
  }

  .no-reviews {
    color: #999;
    font-style: italic;
  }

  .product-actions {
    display: flex;
    gap: 8px;
  }

  .btn-view {
    flex: 1;
    display: inline-block;
    padding: 10px 16px;
    background: #2c3e50;
    color: white;
    text-decoration: none;
    text-align: center;
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .btn-view:hover {
    background: #34495e;
    transform: translateY(-1px);
  }

  .no-results {
    text-align: center;
    padding: 60px 20px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .no-results-icon {
    font-size: 4rem;
    margin-bottom: 20px;
  }

  .no-results h2 {
    font-size: 2rem;
    color: #333;
    margin: 0 0 10px 0;
  }

  .no-results p {
    font-size: 1rem;
    color: #666;
    margin: 10px 0;
  }

  .no-results a {
    color: #2c3e50;
    font-weight: 600;
    text-decoration: none;
  }

  .no-results a:hover {
    text-decoration: underline;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .search-container {
      padding: 20px 15px;
    }

    .search-header h1 {
      font-size: 1.8rem;
    }

    .search-form-wrapper {
      padding: 20px;
    }

    .search-input-group {
      flex-direction: column;
    }

    .search-input {
      min-width: unset;
    }

    .products-grid {
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 16px;
    }

    .product-image {
      height: 200px;
    }

    .product-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .product-price {
      font-size: 1.1rem;
    }
  }

  @media (max-width: 480px) {
    .products-grid {
      grid-template-columns: 1fr;
    }

    .search-header h1 {
      font-size: 1.5rem;
    }

    .no-results-icon {
      font-size: 3rem;
    }
  }
</style>
