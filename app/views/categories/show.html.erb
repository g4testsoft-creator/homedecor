<h1 class="heading"><%= @category.name %></h1>

<% if @category.description.present? %>
  <p class="category-description"><%= @category.description %></p>
<% end %>

<div class="decor-items-grid">
  <% @products.each do |item| %>
    <div class="decor-card-wrapper">
      <%= link_to product_path(item), class: "decor-card-link" do %>
        <div class="decor-card">
          <% if item.images.attached? %>
            <div class="card-image">
              <%= image_tag item.images.first, alt: item.name, class: "card-img" %>
            </div>
          <% else %>
            <div class="card-image">
              <img src="https://via.placeholder.com/400x300?text=No+Image" alt="<%= item.name %>" class="card-img">
            </div>
          <% end %>
          
          <% unless item.in_stock? %>
            <div class="out-of-stock-badge">Out of Stock</div>
          <% end %>
          
          <div class="card-content">
            <h3 class="card-title"><%= item.name %></h3>
            
            <% if item.description.present? %>
              <p class="card-description"><%= truncate(item.description, length: 100) %></p>
            <% end %>
            
            <% if item.price.present? %>
              <div class="card-price">
                <strong><%= format_price(item.price) %></strong>
              </div>
            <% end %>
            
            <% if item.respond_to?(:average_rating) && item.average_rating > 0 %>
              <div class="card-rating">
                <span class="stars">
                  <% item.average_rating.to_i.times do %>★<% end %>
                  <% (5 - item.average_rating.to_i).times do %>☆<% end %>
                </span>
                <span class="rating-value">(<%= item.average_rating %>)</span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      
      <form class="card-add-to-cart" action="<%= add_item_cart_path %>" method="post" data-controller="add-to-cart" data-product-name="<%= item.name %>">
        <input type="hidden" name="product_id" value="<%= item.id %>">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="card-add-btn">Add to Cart</button>
      </form>
      
    </div>
  <% end %>
</div>

<% if @products.respond_to?(:total_pages) %>
  <div class="pagination">
    <%= paginate @products %>
  </div>
<% end %>

<style>
  .decor-card {
    position: relative;
  }
  
  .card-image {
    position: relative;
  }

  .heading {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
    padding: 40px 24px 0 24px;
    letter-spacing: -0.02em;
  }
  
  /* Category Description Styles */
  .category-description {
    padding: 12px 24px 30px 24px;
    color: #666;
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 800px;
    margin: 0;
    border-bottom: 1px solid #eee;
  }
  
  /* Grid Layout */
  .decor-items-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 28px;
    padding: 40px 24px;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Card Wrapper */
  .decor-card-wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  
  /* Card Link */
  .decor-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
    flex: 1;
  }

  /* Card Add to Cart Form */
  .card-add-to-cart {
    background: white;
    border-top: 1px solid #f0f0f0;
  }

  .card-add-btn {
    width: 100%;
    padding: 10px 12px;
    background: #2c3e50;
    color: white;
    border: none;
    border-radius: 0 0 12px 12px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.05s ease;
  }

  .card-add-btn:hover {
    background: #34495e;
    transform: translateY(-2px);
  }

  .card-add-btn:active {
    transform: scale(0.98);
  }
  
  /* Card Styles */
  .decor-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid #f0f0f0;
  }
  
  .decor-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 30px rgba(0, 0, 0, 0.12);
    border-color: #ddd;
  }
  
  /* Card Image */
  .card-image {
    width: 100%;
    height: 284px;
    overflow: hidden;
    position: relative;
    background-color: #f5f5f5;
  }
  
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  
  .decor-card:hover .card-img {
    transform: scale(1.08);
  }
  
  .out-of-stock-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(198, 40, 40, 0.95);
    color: white;
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 12px rgba(198, 40, 40, 0.3);
    backdrop-filter: blur(4px);
    z-index: 10;
  }
  
  /* Card Content */
  .card-content {
    padding: 20px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    background: white;
  }
  
  /* Card Title */
  .card-title {
    margin: 0 0 12px 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: 3.2rem;
  }
  
  /* Card Description */
  .card-description {
    margin: 0 0 16px 0;
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: 4.5rem;
  }
  
  /* Card Price */
  .card-price {
    color: #2c3e50;
    font-size: 1.3rem;
    font-weight: 700;
    padding-top: 12px;
    border-top: 2px solid #f0f0f0;
    margin-top: auto;
    margin-bottom: 8px;
  }
  
  .card-price strong {
    font-weight: 700;
    color: #1a1a1a;
  }
  
  /* Optional Rating Styles */
  .card-rating {
    display: flex;
    align-items: center;
    margin-top: 8px;
    color: #f1c40f;
  }
  
  .stars {
    font-size: 1.1rem;
    letter-spacing: 2px;
    margin-right: 6px;
  }
  
  .rating-value {
    color: #666;
    font-size: 0.9rem;
    font-weight: 500;
  }
  
  /* Pagination Styles */
  .pagination {
    padding: 40px 24px 60px 24px;
    text-align: center;
    border-top: 1px solid #eee;
    margin-top: 20px;
  }
  
  .pagination a, 
  .pagination span {
    display: inline-block;
    padding: 10px 16px;
    margin: 0 5px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    color: #333;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s ease;
    min-width: 40px;
  }
  
  .pagination a:hover {
    background-color: #2c3e50;
    color: white;
    border-color: #2c3e50;
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(44, 62, 80, 0.2);
  }
  
  .pagination .current {
    background-color: #2c3e50;
    color: white;
    border-color: #2c3e50;
    font-weight: 600;
    box-shadow: 0 4px 10px rgba(44, 62, 80, 0.2);
  }
  
  .pagination .prev,
  .pagination .next {
    padding: 10px 20px;
    font-weight: 600;
  }
  
  .pagination .disabled {
    color: #ccc;
    border-color: #eee;
    pointer-events: none;
    cursor: not-allowed;
  }
  
  /* Empty State */
  .no-items {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 1.1rem;
    grid-column: 1 / -1;
  }
  
  /* Responsive Design */
  @media (max-width: 768px) {
    .heading {
      font-size: 2rem;
      padding: 30px 20px 0 20px;
    }
    
    .category-description {
      padding: 10px 20px 25px 20px;
      font-size: 1rem;
    }
    
    .decor-items-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 20px;
      padding: 30px 20px;
    }
    
    .card-image {
      height: 284px;
    }
    
    .card-content {
      padding: 16px;
    }
    
    .card-title {
      font-size: 1.1rem;
      min-height: 2.8rem;
    }
    
    .card-description {
      font-size: 0.9rem;
      min-height: 4rem;
    }
    
    .card-price {
      font-size: 1.1rem;
    }
    
    .pagination {
      padding: 30px 20px 50px 20px;
    }
    
    .pagination a, 
    .pagination span {
      padding: 8px 12px;
      margin: 0 3px;
      font-size: 0.9rem;
    }
  }
  
  @media (max-width: 480px) {
    .heading {
      font-size: 1.8rem;
      padding: 25px 16px 0 16px;
    }
    
    .category-description {
      padding: 8px 16px 20px 16px;
      font-size: 0.95rem;
    }
    
    .decor-items-grid {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 20px 16px;
    }
    
    .card-image {
      height: 284px;
    }
    
    .pagination a, 
    .pagination span {
      padding: 6px 10px;
      margin: 0 2px;
    }
    
    .pagination .prev,
    .pagination .next {
      padding: 6px 12px;
    }
  }
  
  /* Optional: Add loading animation */
  .decor-card {
    animation: fadeIn 0.5s ease-in-out;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Stagger animation for cards */
  .decor-card:nth-child(1) { animation-delay: 0.1s; }
  .decor-card:nth-child(2) { animation-delay: 0.2s; }
  .decor-card:nth-child(3) { animation-delay: 0.3s; }
  .decor-card:nth-child(4) { animation-delay: 0.4s; }
  .decor-card:nth-child(5) { animation-delay: 0.5s; }
  .decor-card:nth-child(6) { animation-delay: 0.6s; }
</style>