<h2>Order Confirmation</h2>

<p>Hello <%= @order.email %>,</p>

<p>Thank you for your order! Here are your order details:</p>

<h3>Order #<%= @order.id %></h3>

<table cellpadding="10" cellspacing="0" style="width: 100%; border-collapse: collapse;">
  <tr style="background-color: #f5f5f5;">
    <th>Product</th>
    <th>Quantity</th>
    <th>Unit Price</th>
    <th>Total</th>
  </tr>
  <% @order_items.each do |item| %>
    <tr>
      <td><%= item.product.name %></td>
      <td><%= item.quantity %></td>
      <td><%= format_price(item.unit_price) %></td>
      <td><%= format_price(item.unit_price * item.quantity) %></td>
    </tr>
  <% end %>
</table>

<p style="margin-top: 20px;">
  <strong>Subtotal:</strong> <%= format_price(@order.subtotal) %><br>
  <strong>Tax (8%):</strong> <%= format_price(@order.tax) %><br>
  <strong>Total:</strong> <%= format_price(@order.total) %>
</p>

<h3>Shipping Address</h3>
<p>
  <%= @order.shipping_address %><br>
  <%= @order.shipping_city %> <%= @order.shipping_zip %><br>
  <%= @order.shipping_country %>
</p>

<h3>Payment Method</h3>
<p><%= @order.payment_method.upcase %></p>

<p style="margin-top: 30px; color: #666; font-size: 12px;">
  If you have any questions about your order, please contact our customer support team.
</p>
