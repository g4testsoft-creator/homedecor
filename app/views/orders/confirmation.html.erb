  /* Responsive Design */
  @media (max-width: 768px) {
    .confirmation-container {
      padding: 20px;
    }

    .confirmation-content {
      padding: 20px;
    }

    .details-grid {
      grid-template-columns: 1fr;
    }

    .items-header,
    .items-row {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .col-price,
    .col-total {
      text-align: left;
    }

    .steps {
      grid-template-columns: 1fr;
    }

    .confirmation-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }
  }
</style>
