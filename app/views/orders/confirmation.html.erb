<div class="confirmation-container">
  <div class="confirmation-success">
    <div class="success-icon">✓</div>
    <h1 class="success-title">Order Confirmed!</h1>
    <p class="success-message">Thank you for your purchase. Your order has been successfully placed.</p>
  </div>

  <div class="confirmation-content">
    <!-- Order Details -->
    <div class="order-details-section">
      <h2 class="section-title">Order Details</h2>
      
      <div class="details-grid">
        <div class="detail-item">
          <label>Order Number</label>
          <p class="detail-value"><%= @order.order_number %></p>
        </div>
        
        <div class="detail-item">
          <label>Order Date</label>
          <p class="detail-value"><%= @order.created_at.strftime("%B %d, %Y") %></p>
        </div>
        
        <div class="detail-item">
          <label>Order Status</label>
          <p class="detail-value status-badge status-<%= @order.status %>">
            <%= @order.status.humanize %>
          </p>
        </div>
        
        <div class="detail-item">
          <label>Expected Delivery</label>
          <p class="detail-value"><%= (@order.created_at + 5.days).strftime("%B %d, %Y") %></p>
        </div>
      </div>
    </div>

    <!-- Items -->
    <div class="order-items-section">
      <h2 class="section-title">Items Ordered</h2>
      
      <div class="items-table">
        <div class="items-header">
          <div class="col-product">Product</div>
          <div class="col-qty">Quantity</div>
          <div class="col-price">Unit Price</div>
          <div class="col-total">Total</div>
        </div>

        <% @order.order_items.each do |item| %>
          <div class="items-row">
            <div class="col-product">
              <%= link_to item.product.name, product_path(item.product), class: "product-link" %>
            </div>
            <div class="col-qty"><%= item.quantity %></div>
            <div class="col-price"><%= format_price(item.unit_price) %></div>
            <div class="col-total"><%= format_price(item.item_total) %></div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Shipping Address -->
    <div class="shipping-section">
      <h2 class="section-title">Shipping Address</h2>
      
      <div class="address-box">
        <p><%= @order.shipping_address %></p>
        <p><%= @order.shipping_city %> <%= @order.shipping_zip %></p>
        <p><%= @order.shipping_country %></p>
        <p class="contact-info"><strong>Phone:</strong> <%= @order.phone %></p>
        <p class="contact-info"><strong>Email:</strong> <%= @order.email %></p>
      </div>
    </div>

    <!-- Order Summary -->
    <div class="order-summary-section">
      <h2 class="section-title">Order Summary</h2>
      
      <div class="summary-box">
        <div class="summary-line">
          <span>Subtotal:</span>
          <span><%= format_price(@order.subtotal) %></span>
        </div>
        
        <div class="summary-line">
          <span>Tax (8%):</span>
          <span><%= format_price(@order.tax) %></span>
        </div>
        
        <div class="summary-line">
          <span>Shipping:</span>
          <span class="free">FREE</span>
        </div>
        
        <div class="summary-divider"></div>
        
        <div class="summary-line total">
          <span>Total Amount:</span>
          <span><%= format_price(@order.total) %></span>
        </div>

        <div class="payment-method">
          <strong>Payment Method:</strong>
          <%= @order.payment_method&.humanize %>
        </div>
      </div>
    </div>

    <!-- Next Steps -->
    <div class="next-steps-section">
      <h2 class="section-title">What's Next?</h2>
      
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Confirmation Email</h3>
            <p>A confirmation email has been sent to <strong><%= @order.email %></strong></p>
          </div>
        </div>
        
        <div class="step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>Processing</h3>
            <p>Your order is being processed and will be shipped within 2-3 business days.</p>
          </div>
        </div>
        
        <div class="step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Tracking</h3>
            <p>You'll receive a shipping notification with tracking information.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="confirmation-actions">
      <%= link_to "Continue Shopping", products_path, class: "btn btn-primary" %>
      <%= link_to "Back to Home", root_path, class: "btn btn-secondary" %>
    </div>
  </div>
</div>

<style>
  .confirmation-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .confirmation-success {
    text-align: center;
    margin-bottom: 50px;
    padding: 40px;
    background: #f0f9ff;
    border-radius: 12px;
  }

  .success-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    background: #27ae60;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    line-height: 1;
  }

  .success-title {
    font-size: 2.2rem;
    color: #27ae60;
    margin-bottom: 10px;
  }

  .success-message {
    font-size: 1.1rem;
    color: #666;
    margin: 0;
  }

  .confirmation-content {
    background: white;
    border-radius: 12px;
    padding: 40px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .section-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 2px solid #f0f0f0;
  }

  .details-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    margin-bottom: 40px;
  }

  .detail-item label {
    display: block;
    font-weight: 600;
    color: #666;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .detail-value {
    font-size: 1.1rem;
    color: #333;
    margin: 0;
  }

  .status-badge {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .status-pending {
    background: #fff3cd;
    color: #856404;
  }

  .status-processing {
    background: #cfe2ff;
    color: #084298;
  }

  .status-shipped {
    background: #d1ecf1;
    color: #055160;
  }

  .status-delivered {
    background: #d4edda;
    color: #155724;
  }

  .order-items-section {
    margin-bottom: 40px;
  }

  .items-table {
    background: #f9f9f9;
    border-radius: 8px;
    overflow: hidden;
  }

  .items-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 20px;
    padding: 16px;
    background: #f0f0f0;
    font-weight: 600;
    color: #666;
    font-size: 0.9rem;
  }

  .items-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 20px;
    padding: 16px;
    border-bottom: 1px solid #f0f0f0;
    align-items: center;
  }

  .items-row:last-child {
    border-bottom: none;
  }

  .col-product {
    text-align: left;
  }

  .product-link {
    color: #2c3e50;
    text-decoration: none;
    font-weight: 500;
  }

  .product-link:hover {
    text-decoration: underline;
  }

  .col-qty,
  .col-price,
  .col-total {
    text-align: right;
  }

  .shipping-section {
    margin-bottom: 40px;
  }

  .address-box {
    background: #f9f9f9;
    padding: 20px;
    border-radius: 8px;
    line-height: 1.8;
  }

  .address-box p {
    margin: 0 0 8px 0;
    color: #333;
  }

  .address-box p:last-child {
    margin-bottom: 0;
  }

  .contact-info {
    margin-top: 15px;
  }

  .order-summary-section {
    margin-bottom: 40px;
  }

  .summary-box {
    background: #f9f9f9;
    padding: 24px;
    border-radius: 8px;
  }

  .summary-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    font-size: 1rem;
    color: #666;
  }

  .summary-line span:last-child {
    font-weight: 600;
    color: #333;
  }

  .free {
    color: #27ae60;
    font-weight: 600;
  }

  .summary-divider {
    height: 1px;
    background: #e0e0e0;
