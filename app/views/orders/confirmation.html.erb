  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .step {
    display: flex;
    gap: 15px;
  }

  .step-number {
    width: 40px;
    height: 40px;
    min-width: 40px;
    background: #2c3e50;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
  }

  .step-content h3 {
    margin: 0 0 8px 0;
    color: #333;
    font-size: 1rem;
  }

  .step-content p {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
  }

  .confirmation-actions {
    display: flex;
    gap: 15px;
    justify-content: center;
  }

  .btn {
    display: inline-block;
    padding: 12px 30px;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
