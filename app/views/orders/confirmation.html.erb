    color: #666;
  }

  .next-steps-section {
    margin-bottom: 40px;
    background: #f0f9ff;
    padding: 30px;
    border-radius: 8px;
  }

  .next-steps-section .section-title {
    border-bottom-color: #d1ecf1;
