<div class="checkout-container">
  <h1 class="checkout-title">Checkout</h1>

  <div class="checkout-content">
    <div class="checkout-form-section">
      <%= form_with(model: @order, local: true, class: "checkout-form", data: { controller: "checkout-form" }) do |form| %>

        <!-- Contact Information -->
        <fieldset class="form-section">
          <legend>Contact Information</legend>
          
          <div class="form-group">
            <%= form.label :email %>
            <%= form.email_field :email, class: "form-control" + (@order.errors.include?(:email) ? " field-error" : ""), placeholder: "your@email.com", required: true, data: { "checkout-form-target": "field" } %>
            <% if @order.errors.include?(:email) %>
              <p class="field-error-text"><%= @order.errors[:email].join(", ") %></p>
            <% end %>
          </div>

          <div class="form-group">
            <%= form.label :phone %>
            <%= form.telephone_field :phone, class: "form-control" + (@order.errors.include?(:phone) ? " field-error" : ""), placeholder: "(555) 123-4567", required: true, data: { "checkout-form-target": "field" } %>
            <% if @order.errors.include?(:phone) %>
              <p class="field-error-text"><%= @order.errors[:phone].join(", ") %></p>
            <% end %>
          </div>
        </fieldset>

        <!-- Shipping Address -->
        <fieldset class="form-section">
          <legend>Shipping Address</legend>
          
          <div class="form-group">
            <%= form.label :shipping_address, "Street Address" %>
            <%= form.text_field :shipping_address, class: "form-control" + (@order.errors.include?(:shipping_address) ? " field-error" : ""), placeholder: "123 Main Street", required: true, data: { "checkout-form-target": "field" } %>
            <% if @order.errors.include?(:shipping_address) %>
              <p class="field-error-text"><%= @order.errors[:shipping_address].join(", ") %></p>
            <% end %>
          </div>

          <div class="form-row">
            <div class="form-group">
              <%= form.label :shipping_city, "City" %>
              <%= form.text_field :shipping_city, class: "form-control" + (@order.errors.include?(:shipping_city) ? " field-error" : ""), placeholder: "New York", required: true, data: { "checkout-form-target": "field" } %>
              <% if @order.errors.include?(:shipping_city) %>
                <p class="field-error-text"><%= @order.errors[:shipping_city].join(", ") %></p>
              <% end %>
            </div>

            <div class="form-group">
              <%= form.label :shipping_state, "State" %>
              <%= form.text_field :shipping_state, class: "form-control" + (@order.errors.include?(:shipping_state) ? " field-error" : ""), placeholder: "NY", required: true, data: { "checkout-form-target": "field" } %>
              <% if @order.errors.include?(:shipping_state) %>
                <p class="field-error-text"><%= @order.errors[:shipping_state].join(", ") %></p>
              <% end %>
            </div>

            <div class="form-group">
              <%= form.label :shipping_zip, "ZIP Code" %>
              <%= form.text_field :shipping_zip, class: "form-control" + (@order.errors.include?(:shipping_zip) ? " field-error" : ""), placeholder: "10001", required: true, data: { "checkout-form-target": "field" } %>
              <% if @order.errors.include?(:shipping_zip) %>
                <p class="field-error-text"><%= @order.errors[:shipping_zip].join(", ") %></p>
              <% end %>
            </div>
          </div>

          <div class="form-group">
            <%= form.label :shipping_country, "Country" %>
            <%= form.text_field :shipping_country, class: "form-control" + (@order.errors.include?(:shipping_country) ? " field-error" : ""), placeholder: "United States", required: true, data: { "checkout-form-target": "field" } %>
            <% if @order.errors.include?(:shipping_country) %>
              <p class="field-error-text"><%= @order.errors[:shipping_country].join(", ") %></p>
            <% end %>
          </div>
        </fieldset>

        <!-- Payment Method -->
        <fieldset class="form-section">
          <legend>Payment Method</legend>
          
          <div class="payment-methods">
            <!-- Credit Card Option -->
            <div class="payment-option-group">
              <label class="payment-option-label">
                <%= radio_button_tag :payment_method, 'card', true, { class: "payment-radio" } %>
                <span class="payment-option-text">
                  <strong>Credit/Debit Card</strong>
                  <span class="payment-option-cards">Visa, Mastercard, Amex</span>
                </span>
              </label>
              
              <div class="payment-card-section" id="stripe-element-section">
                <div id="card-element" class="card-element-container"></div>
                <div id="card-errors" class="card-errors"></div>
              </div>
            </div>

            <!-- Cash on Delivery Option -->
            <div class="payment-option-group">
              <label class="payment-option-label">
                <%= radio_button_tag :payment_method, 'cash', false, { class: "payment-radio" } %>
                <span class="payment-option-text">
                  <strong>Cash on Delivery</strong>
                  <span class="payment-option-desc">Pay when your order arrives</span>
                </span>
              </label>
            </div>
          </div>
        </fieldset>

        <div class="checkout-actions">
          <input type="hidden" id="payment-intent-id" name="payment_intent_id" value="">
          <%= form.submit "Place Order", class: "btn btn-primary btn-lg", id: "place-order-btn", disabled: false, data: { "checkout-form-target": "submitBtn" } %>
          <%= link_to "Back to Cart", cart_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>

    <!-- Order Summary Sidebar -->
    <div class="order-summary-section">
      <div class="order-summary">
        <h2 class="summary-title">Order Summary</h2>

        <div class="summary-items">
          <% @cart.cart_items.each do |item| %>
            <div class="summary-item">
              <div class="item-info">
                <p class="item-name"><%= item.product.name %></p>
                <p class="item-quantity">Qty: <%= item.quantity %></p>
              </div>
              <p class="item-price">
                <%= number_to_currency(item.product.price * item.quantity) %>
              </p>
            </div>
          <% end %>
        </div>

        <div class="summary-divider"></div>

        <div class="summary-line">
          <span>Subtotal:</span>
          <span><%= number_to_currency(@cart.total_price) %></span>
        </div>

        <div class="summary-line">
          <span>Tax (8%):</span>
          <span><%= number_to_currency(@cart.total_price * 0.08) %></span>
        </div>

        <div class="summary-line">
          <span>Shipping:</span>
          <span class="free-shipping">FREE</span>
        </div>

        <div class="summary-line summary-total">
          <span>Total:</span>
          <span><%= number_to_currency(@cart.total_price * 1.08) %></span>
        </div>

        <div class="summary-note">
          <p>✓ Free shipping on all orders</p>
          <p>✓ 30-day money-back guarantee</p>
          <p>✓ Secure checkout</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .checkout-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .checkout-title {
    font-size: 2rem;
    color: #333;
    margin-bottom: 40px;
    border-bottom: 2px solid #f0f0f0;
    padding-bottom: 20px;
  }

  .checkout-content {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 40px;
  }

  .checkout-form-section {
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    padding: 30px;
  }

  .form-section {
    margin-bottom: 30px;
    padding-bottom: 30px;
    border-bottom: 1px solid #f0f0f0;
    border: none;
  }

  .form-section:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .form-section legend {
    font-size: 1.2rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 20px;
    display: block;
    padding: 0;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    font-weight: 500;
    color: #333;
    margin-bottom: 8px;
    font-size: 0.95rem;
  }

  .form-control {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 1rem;
    font-family: inherit;
    transition: all 0.2s ease;
  }

  .form-control:focus {
    outline: none;
    border-color: #2c3e50;
    box-shadow: 0 0 0 3px rgba(44, 62, 80, 0.1);
  }

  .form-control.field-error {
    border-color: #dc3545 !important;
    box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.15) !important;
  }

  .form-control.field-error:focus {
    border-color: #dc3545 !important;
    box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.15) !important;
  }

  .field-error-text {
    color: #dc3545;
    font-size: 0.875rem;
    margin-top: 4px;
    margin-bottom: 0;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 100px 120px;
    gap: 20px;
  }

  .payment-options {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .payment-option {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    padding: 12px;
    border: 2px solid #f0f0f0;
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .payment-option input[type="radio"] {
    cursor: pointer;
    width: 20px;
    height: 20px;
  }

  .payment-option:hover {
    border-color: #2c3e50;
    background: #f9f9f9;
  }

  .payment-option input[type="radio"]:checked + span {
    font-weight: 600;
  }

  .payment-option span {
    font-size: 1rem;
    color: #333;
  }

  .payment-method-info {
    background: #f0f9ff;
    padding: 20px;
    border-radius: 8px;
    border: 2px solid #d1ecf1;
  }

  .payment-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    color: #055160;
    font-weight: 600;
  }

  .payment-badge svg {
    color: #055160;
  }

  .payment-description {
    color: #666;
    font-size: 0.95rem;
    margin: 0;
  }

  .checkout-actions {
    display: flex;
    gap: 15px;
    margin-top: 30px;
  }

  .btn {
    padding: 12px 20px;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .btn-primary {
    background: #2c3e50;
    color: white;
    flex: 1;
  }

  .btn-primary:hover {
    background: #34495e;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(44, 62, 80, 0.2);
  }

  .btn-primary:disabled,
  .btn-disabled {
    background: #ccc;
    color: #999;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .btn-primary:disabled:hover,
  .btn-disabled:hover {
    background: #ccc;
  }

  .btn-lg {
    padding: 14px 24px;
    font-size: 1.1rem;
  }

  .btn-secondary {
    background: #f5f5f5;
    color: #333;
    border: 1px solid #ddd;
    flex: 1;
  }

  .btn-secondary:hover {
    background: #e9e9e9;
    border-color: #bbb;
  }

  .order-summary-section {
    position: relative;
  }

  .order-summary {
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    padding: 24px;
    position: sticky;
    top: 20px;
  }

  .summary-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 20px;
  }

  .summary-items {
    margin-bottom: 20px;
    max-height: 300px;
    overflow-y: auto;
  }

  .summary-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    padding-bottom: 15px;
    border-bottom: 1px solid #f0f0f0;
  }

  .summary-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .item-info {
    flex: 1;
  }

  .item-name {
    font-weight: 500;
    color: #333;
    margin: 0 0 4px 0;
    font-size: 0.95rem;
  }

  .item-quantity {
    color: #999;
    font-size: 0.85rem;
    margin: 0;
  }

  .item-price {
    font-weight: 600;
    color: #2c3e50;
    margin: 0;
    white-space: nowrap;
  }

  .summary-divider {
    height: 1px;
    background: #f0f0f0;
    margin: 20px 0;
  }

  .summary-line {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 0.95rem;
    color: #666;
  }

  .summary-line span:last-child {
    font-weight: 600;
    color: #333;
  }

  .free-shipping {
    color: #27ae60;
    font-weight: 600;
  }

  .summary-total {
    padding-top: 12px;
    border-top: 2px solid #f0f0f0;
    font-size: 1.2rem;
    color: #2c3e50;
  }

  .summary-total span:last-child {
    font-size: 1.3rem;
  }

  .summary-note {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #f0f0f0;
  }

  .summary-note p {
    margin: 8px 0;
    font-size: 0.85rem;
    color: #27ae60;
  }

  .alert {
    padding: 15px;
    border-radius: 6px;
    margin-bottom: 20px;
  }

  .alert-danger {
    background: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
  }

  .alert-danger h4 {
    margin-top: 0;
  }

  .alert-danger ul {
    margin-bottom: 0;
    padding-left: 20px;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .checkout-content {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .checkout-form-section {
      padding: 20px;
    }

    .order-summary {
      position: static;
      margin-top: 20px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .checkout-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }
  }

  /* Stripe Payment Styles */
  .payment-methods {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .payment-option-group {
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 16px;
    transition: all 0.2s ease;
  }

  .payment-option-group:has(.payment-radio:checked) {
    border-color: #2c3e50;
    background: #f9f9f9;
  }

  .payment-option-label {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    cursor: pointer;
    margin-bottom: 12px;
  }

  .payment-radio {
    margin-top: 4px;
    cursor: pointer;
    width: 18px;
    height: 18px;
    accent-color: #2c3e50;
  }

  .payment-option-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .payment-option-text strong {
    color: #333;
    font-size: 1rem;
  }

  .payment-option-cards,
  .payment-option-desc {
    font-size: 0.85rem;
    color: #999;
  }

  .payment-card-section {
    display: none;
  }

  .payment-option-group:has(.payment-radio:checked) .payment-card-section {
    display: block;
    padding-top: 16px;
    border-top: 1px solid #ddd;
  }

  .card-element-container {
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    margin-bottom: 12px;
    background: white;
  }

  .StripeElement {
    box-sizing: border-box;
    height: 40px;
    padding: 10px 12px;
    border: 1px solid #ced4da;
    border-radius: 4px;
    background-color: white;
    box-shadow: 0 1px 3px 0 #e6ebf1;
    -webkit-transition: box-shadow 150ms ease;
    transition: box-shadow 150ms ease;
  }

  .StripeElement--focus {
    box-shadow: 0 1px 3px 0 #cfd7df;
    border-color: #2c3e50;
  }

  .StripeElement--invalid {
    border-color: #dc3545;
  }

  .card-errors {
    color: #dc3545;
    margin-bottom: 12px;
    font-size: 0.85rem;
    min-height: 20px;
  }
</style>

<script src="https://js.stripe.com/v3/"></script>

<script>
  function initializeStripeCheckout() {
    if (typeof Stripe === 'undefined') {
      console.warn('Stripe not loaded yet, retrying...');
      setTimeout(initializeStripeCheckout, 500);
      return;
    }

    console.log("Initializing Stripe checkout");
    const stripe = Stripe('<%= @stripe_publishable_key %>');
    const elements = stripe.elements();
    const cardElement = elements.create('card');

    // Only mount if element exists
    const cardElementContainer = document.getElementById('card-element');
    if (cardElementContainer) {
      cardElement.mount('#card-element');

      const cardErrors = document.getElementById('card-errors');
      cardElement.addEventListener('change', function(event) {
        if (event.error) {
          cardErrors.textContent = event.error.message;
        } else {
          cardErrors.textContent = '';
        }
      });

      // Handle payment method switching
      const paymentMethodInputs = document.querySelectorAll('input[name="payment_method"]');
      const form = document.querySelector('.checkout-form');
      const submitBtn = document.getElementById('place-order-btn');

      paymentMethodInputs.forEach(input => {
        input.addEventListener('change', function() {
          if (this.value === 'card') {
            form.dataset.paymentMethod = 'card';
          } else {
            form.dataset.paymentMethod = 'cash';
          }
        });
      });

      // Form submission
      if (form) {
        form.addEventListener('submit', async function(e) {
          e.preventDefault();

          // Validate required fields
          const requiredFields = [
            'order_email',
            'order_phone',
            'order_shipping_address',
            'order_shipping_city',
            'order_shipping_state',
            'order_shipping_zip',
            'order_shipping_country'
          ];

          let allFieldsValid = true;
          const errors = [];

          requiredFields.forEach(fieldId => {
            const field = document.getElementById(fieldId);
            if (field && (!field.value || field.value.trim() === '')) {
              allFieldsValid = false;
              const fieldLabel = field.previousElementSibling?.textContent || fieldId;
              errors.push(`${fieldLabel} is required`);
              field.classList.add('field-error');
            } else if (field) {
              field.classList.remove('field-error');
            }
          });

          if (!allFieldsValid) {
            document.getElementById('card-errors').textContent = errors.join(', ');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Place Order';
            return;
          }

          const selectedMethod = document.querySelector('input[name="payment_method"]:checked').value;

          if (selectedMethod === 'card') {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Processing...';

            // Create payment intent on the backend
            try {
              const response = await fetch('<%= create_payment_intent_orders_path %>', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
                },
                body: JSON.stringify({
                  amount: <%= (@cart.total_price * 1.08 * 100).to_i %>,
                  email: document.querySelector('#order_email').value
                })
              });

              const paymentData = await response.json();

              if (paymentData.error) {
                document.getElementById('card-errors').textContent = paymentData.error;
                submitBtn.disabled = false;
                submitBtn.textContent = 'Place Order';
                return;
              }

              // Confirm card payment
              const result = await stripe.confirmCardPayment(paymentData.client_secret, {
                payment_method: {
                  card: cardElement,
                  billing_details: {
                    email: document.querySelector('#order_email').value,
                    address: {
                      line1: document.querySelector('#order_shipping_address').value,
                      city: document.querySelector('#order_shipping_city').value,
                      state: document.querySelector('#order_shipping_state').value,
                      postal_code: document.querySelector('#order_shipping_zip').value,
                      country: 'US'
                    }
                  }
                }
              });

              if (result.error) {
                document.getElementById('card-errors').textContent = result.error.message;
                submitBtn.disabled = false;
                submitBtn.textContent = 'Place Order';
              } else {
                // Payment succeeded, set the intent ID and submit
                document.getElementById('payment-intent-id').value = result.paymentIntent.id;
                form.submit();
              }
            } catch (error) {
              document.getElementById('card-errors').textContent = 'An error occurred. Please try again.';
              submitBtn.disabled = false;
              submitBtn.textContent = 'Place Order';
            }
          } else {
            // Cash on delivery - just submit the form
            form.submit();
          }
        });
      }
    }
  }

  // Initialize on DOMContentLoaded and Turbo events
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeStripeCheckout);
  } else {
    initializeStripeCheckout();
  }

  // Also listen for Turbo navigation
  document.addEventListener('turbo:load', initializeStripeCheckout);
  document.addEventListener('turbo:render', initializeStripeCheckout);
</script>
