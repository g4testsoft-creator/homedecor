<div class="cart-container">
  <h1 class="cart-title">Shopping Cart</h1>

  <% if @cart_items.any? %>
    <div id="cart_items_list" class="cart-items-section">
      <%= render "cart_items_list", cart_items: @cart_items %>
    </div>

    <div class="cart-summary">
      <div id="cart_total" class="cart-total-section">
        <%= render "cart_total" %>
      </div>

      <div class="cart-actions">
        <%= button_to "Clear Cart", clear_cart_path, method: :post, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
        <%= link_to "Continue Shopping", decor_items_path, class: "btn btn-secondary" %>
        <%= link_to "Checkout", "#", class: "btn btn-primary" %>
      </div>
    </div>
  <% else %>
    <div class="empty-cart">
      <p class="empty-cart-message">Your cart is empty</p>
      <%= link_to "Continue Shopping", decor_items_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<style>
  .cart-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .cart-title {
    font-size: 2rem;
    color: #333;
    margin-bottom: 30px;
    border-bottom: 2px solid #f0f0f0;
    padding-bottom: 20px;
  }

  .cart-items-section {
    margin-bottom: 30px;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 120px 1fr auto auto;
    gap: 20px;
    align-items: center;
    padding: 20px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    margin-bottom: 16px;
    border: 1px solid #f0f0f0;
  }

  .cart-item-image {
    width: 120px;
    height: 120px;
    border-radius: 8px;
    overflow: hidden;
    background: #f5f5f5;
  }

  .cart-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item-details {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cart-item-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: #333;
    margin: 0;
    text-decoration: none;
    cursor: pointer;
  }

  .cart-item-name:hover {
    color: #2c3e50;
  }

  .cart-item-price {
    font-size: 1rem;
    color: #666;
    margin: 0;
  }

  .cart-item-controls {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .quantity-input {
    width: 70px;
    padding: 8px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 1rem;
    text-align: center;
  }

  .quantity-input:focus {
    outline: none;
    border-color: #2c3e50;
    box-shadow: 0 0 0 3px rgba(44, 62, 80, 0.1);
  }

  .update-quantity-btn {
    padding: 6px 10px;
    background: #2c3e50;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.8rem;
    transition: background 0.2s ease;
  }

  .update-quantity-btn:hover {
    background: #34495e;
  }

  .remove-btn {
    padding: 6px 12px;
    background: #dc3545;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85rem;
    transition: background 0.2s ease;
  }

  .remove-btn:hover {
    background: #c82333;
  }

  .cart-item-total {
    font-size: 1.1rem;
    font-weight: 600;
    color: #2c3e50;
    min-width: 100px;
    text-align: right;
  }

  .cart-summary {
    max-width: 400px;
    margin-left: auto;
  }

  .cart-total-section {
    background: white;
    padding: 24px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    margin-bottom: 20px;
    border: 1px solid #f0f0f0;
  }

  .cart-total-line {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 1rem;
    color: #666;
  }

  .cart-total-line strong {
    color: #333;
  }

  .cart-total-final {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 12px;
    border-top: 2px solid #f0f0f0;
    font-size: 1.3rem;
    font-weight: 700;
    color: #2c3e50;
  }

  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .btn {
    display: inline-block;
    padding: 12px 20px;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: #2c3e50;
    color: white;
  }

  .btn-primary:hover {
    background: #34495e;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(44, 62, 80, 0.2);
  }

  .btn-secondary {
    background: #f5f5f5;
    color: #333;
    border: 1px solid #ddd;
  }

  .btn-secondary:hover {
    background: #e9e9e9;
    border-color: #bbb;
  }

  .btn-danger {
    background: #dc3545;
    color: white;
  }

  .btn-danger:hover {
    background: #c82333;
  }

  .empty-cart {
    text-align: center;
    padding: 60px 20px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .empty-cart-message {
    font-size: 1.2rem;
    color: #999;
    margin-bottom: 30px;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .cart-container {
      padding: 20px 16px;
    }

    .cart-title {
      font-size: 1.5rem;
      margin-bottom: 20px;
    }

    .cart-item {
      grid-template-columns: 100px 1fr;
      gap: 16px;
    }

    .cart-item-image {
      width: 100px;
      height: 100px;
    }

    .cart-item-controls {
      grid-column: 1 / -1;
      justify-content: space-between;
    }

    .cart-item-total {
      grid-column: 1 / -1;
      text-align: left;
      margin-top: 10px;
    }

    .cart-summary {
      max-width: 100%;
    }

    .cart-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .cart-item {
      grid-template-columns: 80px 1fr;
    }

    .cart-item-image {
      width: 80px;
      height: 80px;
    }

    .quantity-input {
      width: 60px;
      padding: 6px;
      font-size: 0.9rem;
    }

    .btn {
      padding: 10px 16px;
      font-size: 0.9rem;
    }
  }
</style>
