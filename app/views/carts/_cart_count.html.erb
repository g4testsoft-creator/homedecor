<div id="cart_count" class="cart-count-container">
  <%= link_to cart_path, class: "cart-link" do %>
    <span class="cart-icon">🛒</span>
    <span>Cart</span>
    <% if user_signed_in? && current_user.cart.present? && current_user.cart.total_items > 0 %>
      <span class="cart-count"><%= current_user.cart.total_items %></span>
    <% end %>
  <% end %>
</div>
