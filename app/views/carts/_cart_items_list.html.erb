<% cart_items.each do |cart_item| %>
  <div class="cart-item" id="cart-item-<%= cart_item.id %>">
    <% if cart_item.product.image.attached? %>
      <div class="cart-item-image">
        <%= image_tag cart_item.product.image, alt: cart_item.product.name %>
      </div>
    <% else %>
      <div class="cart-item-image" style="background: #f0f0f0;"></div>
    <% end %>

    <div class="cart-item-details">
      <%= link_to cart_item.product.name, product_path(cart_item.product), class: "cart-item-name" %>
      <p class="cart-item-price"><%= number_to_currency(cart_item.product.price) %> each</p>
    </div>

    <div class="cart-item-controls">
      <input type="number" 
             id="quantity_<%= cart_item.id %>"
             class="quantity-input" 
             value="<%= cart_item.quantity %>" 
             min="1"
             max="999">
      <button type="button"
              class="update-quantity-btn"
              data-product-id="<%= cart_item.product_id %>"
              onclick="updateQuantity('<%= cart_item.product_id %>', this)">Update</button>
      <%= button_to "Remove", 
                    remove_item_cart_path(product_id: cart_item.product_id), 
                    method: :delete,
                    class: "remove-btn" %>
    </div>

    <div class="cart-item-total">
      <%= number_to_currency(cart_item.total_price) %>
    </div>
  </div>
<% end %>

<script>
  function updateQuantity(productId, button) {
    const quantityInput = document.getElementById(`quantity_${productId}`);
    const quantity = quantityInput.value;
    
    const formData = new FormData();
    formData.append('quantity', quantity);
    
    fetch(`<%= update_quantity_cart_path %>?product_id=${productId}`, {
      method: 'PATCH',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: formData
    })
    .then(response => response.text())
    .then(html => {
      // The Turbo stream response will handle the update
    })
    .catch(error => console.error('Error:', error));
  }
</script>
