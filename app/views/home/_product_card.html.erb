<div class="product-card-wrapper">
  <%= link_to product_path(item), class: "decor-card-link" do %>
    <div class="decor-card">
      <% if item.images.attached? && item.images.first.present? %>
        <div class="card-image">
          <%= image_tag item.images.first, alt: item.name, class: "card-img" %>
        </div>
      <% else %>
        <div class="card-image">
          <img src="https://via.placeholder.com/400x300?text=No+Image" alt="<%= item.name %>" class="card-img">
        </div>
      <% end %>
      
      <!-- Out of Stock Badge -->
      <% unless item.in_stock? %>
        <div class="out-of-stock-badge">Out of Stock</div>
      <% end %>
      
      <div class="card-content">
        <h3 class="card-title"><%= item.name %></h3>
        
        <% if item.description.present? %>
          <p class="card-description"><%= truncate(item.description, length: 80) %></p>
        <% end %>
        
        <% if item.price.present? %>
          <div class="card-price">
            <strong>Rs. <%= item.price.to_i %></strong>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <form class="card-add-to-cart" action="<%= add_item_cart_path %>" method="post" data-controller="add-to-cart" data-product-name="<%= item.name %>">
    <input type="hidden" name="product_id" value="<%= item.id %>">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
    <input type="hidden" name="quantity" value="1">
    <button type="submit" class="card-add-btn" <%= 'disabled' unless item.in_stock? %>>
      <%= item.in_stock? ? 'Add to Cart' : 'Out of Stock' %>
    </button>
  </form>
</div>

<style>
  .decor-card {
    position: relative;
  }
  
  .card-image {
    position: relative;
  }

  @media (max-width: 768px) {
    .card-image {
      height: 311px;
    }
  }
  
  .card-add-btn {
    width: 100%;
    padding: 10px 12px;
    background: #2c3e50;
    color: white;
    border: none;
    border-radius: 0 0 12px 12px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.05s ease;
  }
  
  .card-add-btn:disabled {
    background: #cbd5e1;
    color: #94a3b8;
    cursor: not-allowed;
    opacity: 0.6;
  }
  
  .out-of-stock-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(198, 40, 40, 0.95);
    color: white;
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 12px rgba(198, 40, 40, 0.3);
    backdrop-filter: blur(4px);
    z-index: 10;
  }
</style>